# =============================================================================
# FilePilot AI — Environment Configuration Template
# =============================================================================
# This file is for reference only. FilePilot does NOT read .env files.
# All settings are configured through the UI (Settings → AI Engine).
#
# API keys are stored in your operating system's credential manager:
#   Settings → AI Engine → enter API Key → Save
#
# Or via CLI:
#   python -c "import keyring; keyring.set_password('filepilot-ai', 'ai_api_key', 'sk-your-key-here')"
# =============================================================================

# ── AI Provider ──────────────────────────────────────────────────────────────
# Options: ollama | llamacpp | openai | anthropic | custom
# Default: ollama
# AI_PROVIDER=ollama

# ── AI Model ─────────────────────────────────────────────────────────────────
# Default models by provider:
#   ollama:    qwen2.5:7b
#   llamacpp:  /path/to/model.gguf
#   openai:    gpt-4o-mini
#   anthropic: claude-3-haiku-20240307
#   custom:    (custom model name)
# AI_MODEL=qwen2.5:7b

# ── API Base URL ─────────────────────────────────────────────────────────────
# Endpoint for API requests. Defaults vary by provider:
#   ollama:    http://localhost:11434
#   llamacpp:  http://localhost:8080
#   openai:    https://api.openai.com
#   anthropic: https://api.anthropic.com
#   custom:    http://localhost:11434
# AI_API_BASE=http://localhost:11434

# ── API Key (NOT USED — see security note above) ────────────────────────────
# API keys are NOT stored here.
# Use the system keyring instead (Settings → AI Engine → API Key).
#
# The following providers require an API key:
#   openai    → https://platform.openai.com/api-keys
#   anthropic → https://console.anthropic.com/
#   custom    → (your provider's key)
#
# Local providers (ollama, llamacpp) do not require an API key.

# ── General Settings ─────────────────────────────────────────────────────────
# Path for the search index (default: ~/.filepilot/index)
# INDEX_PATH=~/.filepilot/index

# Maximum file size (MB) for scanning (default: 500)
# MAX_FILE_SIZE_MB=500
